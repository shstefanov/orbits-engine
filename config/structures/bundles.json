{
  "path":   ["bundles", "*.js"    ],
  "engine":  "infrastructure-webpack/engine",

  "instances": {
    
    "admin": {
      "prototype": "./lib/bundles/BaseBundle.js",
      "target": "./app/admin",
      "alias": {
        "admin.data": "data.js"
      }
    },
    
    "game": {
      "prototype": "./lib/bundles/BaseBundle.js",
      "target": "./app/game",
      "alias": {
        "game.data": "data.js",
        "game.resources": "resources.js",
        "ViewportController": "lib/ViewportController.js"
      }
    },

    "editor": {
      "prototype": "./lib/bundles/BaseBundle.js",
      "target": "./app/editor",
      "alias": {
        "editor.data": "data.js",
        "editor.resources": "resources.js",

        
        "BaseSidebarComponent": "lib/components/BaseSidebarComponent/index.js",
        "BaseGeometryPropertiesComponent": "lib/components/BaseGeometryPropertiesComponent/index.js"
      }
    },

    "panel": {
      "prototype": "./lib/bundles/BaseBundle.js",
      "target": "./app/panel",
      "alias": {
        "panel.data": "data.js",
        "panel.resources": "resources.js"
      }
    },

    "dev": {
      "prototype": "./lib/bundles/BaseBundle.js",
      "target": "./app/dev",
      "alias": {
        "dev.data": "data.js",
        "dev.resources": "resources.js"
      }
    }



    
  }
}