{
  "engines": ["infrastructure-socketio/engine"],
  "instances": {
    
    "game": {
      "prototype": "./lib/websocket/Handler.js",
      "options": {
        "name":           "game",
        "port":           4004,
        "connect_port":   4004
      },
      "listenSocket": {
        "getBlocks": "data.Blocks.find | | blocks"
      }
    },

    "admin": {
      "prototype": "./lib/websocket/Handler.js",
      "options": {
        "name":           "admin",
        "port":           4005,
        "connect_port":   4005
      },
      "listenSocket": {
        "getBlocks": "data.Blocks.find | | blocks"
      }
    }
    

  }
}