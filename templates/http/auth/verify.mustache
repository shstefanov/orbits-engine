<!DOCTYPE html>
<html>
  <head>
    <title>{{title}}</title>
    {{#javascripts}} <script type="text/javascript" src="{{{.}}}"  ></script> {{/javascripts }}
    {{#styles     }} <link   rel="stylesheet"       href="{{{.}}}"         /> {{/styles      }}
  </head>
  <body>
    <div class="container">
      <div class="row">
        <div class="col-lg-12 text-center">
          <div class="row">
            <form class="form-horizontal col-lg-8 col-md-offset-2" method="POST" action="{{page.root}}/login">
              <fieldset>
                {{#error}}
                  <div class="form-group">
                    <div class="col-md-8 col-md-offset-2">
                      <legend>Error</legend>
                    </div>
                  </div>

                  <div class="form-group">
                    <div class="col-md-8 col-md-offset-2">
                      <p class="alert alert-danger">{{error}}</p>
                    </div>
                  </div>

                  <div class="form-group">
                    <div class="col-md-8 col-md-offset-2">
                      <a href="{{page.root}}/login" class="btn btn-primary form-control">Login</a>
                    </div>
                  </div>

                  <div class="form-group">
                    <div class="col-md-8 col-md-offset-2">
                      <a href="/" class="btn btn-primary form-control">Home page</a>
                    </div>
                  </div>
                {{/error}}
              </fieldset>
            </form>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
